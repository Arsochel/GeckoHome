# GeckoHome configuration. Copy to `.env` and fill in real values.
# Never commit the real .env — it is gitignored.

# ── Web auth ──────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# bcrypt hash of the web password (NOT the plaintext password)
ADMIN_PASSWORD_HASH=
# Session signing secret. If empty, a random one is generated on each restart
# (which logs everyone out on restart) — set a fixed value in production.
SECRET_KEY=

# ── Telegram bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Super-admins (full control: lamps, schedules, feeding). Comma-separated user ids.
TELEGRAM_SUPER_ADMIN=
# Regular admins (read-only-ish). Comma-separated user ids.
TELEGRAM_ADMIN=

# ── Tuya device ids ───────────────────────────────────────────────────────────
DEVICE_UV_LAMP=
DEVICE_HEAT_LAMP=
DEVICE_THERMOMETER=
DEVICE_HUMIDIFIER=

# ── Tuya local LAN (tinytuya) ─────────────────────────────────────────────────
DEVICE_UV_LAMP_IP=
DEVICE_UV_LAMP_LOCAL_KEY=
DEVICE_UV_LAMP_VERSION=3.4
DEVICE_HEAT_LAMP_IP=
DEVICE_HEAT_LAMP_LOCAL_KEY=
DEVICE_HEAT_LAMP_VERSION=3.4
DEVICE_THERMOMETER_IP=
DEVICE_THERMOMETER_LOCAL_KEY=
DEVICE_THERMOMETER_VERSION=3.3
DEVICE_HUMIDIFIER_IP=
DEVICE_HUMIDIFIER_LOCAL_KEY=
DEVICE_HUMIDIFIER_VERSION=3.3

# ── Tuya Cloud (fallback for battery devices without persistent LAN) ──────────
TUYA_CLOUD_KEY=
TUYA_CLOUD_SECRET=
TUYA_CLOUD_REGION=eu

# ── Camera / streaming ────────────────────────────────────────────────────────
CAMERA_RTSP_URL=
# Path to the mediamtx binary (WebRTC proxy). In Docker this is /usr/local/bin/mediamtx.
MEDIAMTX_BIN=mediamtx
STREAM_BASE_URL=http://localhost:8080

# ── Web server ────────────────────────────────────────────────────────────────
SERVER_PORT=8000
# Internal URL the bot uses to reach the web app (set in docker-compose for the bot).
APP_INTERNAL_URL=

# ── YOLO gecko detection ──────────────────────────────────────────────────────
YOLO_MODEL_PATH=

# ── Motion detection tuning ───────────────────────────────────────────────────
MOTION_THRESHOLD=25
MOTION_MIN_AREA=1342
MOTION_TIMEOUT=45
MOTION_DEBUG=true

# ── Sensor alert thresholds ───────────────────────────────────────────────────
# Temperature is stored ×10 (e.g. 200 = 20.0 °C).
TEMP_ALERT_MIN=200
TEMP_ALERT_MAX=350
HUM_ALERT_MIN=30
HUM_ALERT_MAX=60

# ── Feeding ───────────────────────────────────────────────────────────────────
FEEDING_ALERT_DAYS=2

# ── Local sensor ingest ───────────────────────────────────────────────────────
# Shared token for POST /api/sensor/ingest (cloud-free readings from a LAN sensor,
# e.g. an ESP32/ESPHome node). Empty = endpoint disabled.
SENSOR_INGEST_TOKEN=

# ── OpenCV / FFmpeg (advanced; usually leave as set in code) ──────────────────
# OPENCV_FFMPEG_CAPTURE_OPTIONS=rtsp_transport;tcp
# OPENCV_FFMPEG_LOGLEVEL=-8
# OPENCV_LOG_LEVEL=ERROR
